<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent">

  <!-- House Image Background -->
  <ImageView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:src="@drawable/your_house_image"
    android:scaleType="centerCrop" />

  <!-- Shadow Overlay -->
  <View
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#A0000000" />

  <!-- Content -->
  <ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:gravity="center"
      android:padding="32dp">

      <!-- Logo with Circular Background -->
      <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="50dp"
        android:background="@drawable/circular_logo_background"
        android:padding="8dp"
        android:src="@drawable/ic_menu_home" />

      <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:text="@string/welcome_brand"
        android:textColor="#F6F6F6"
        android:textSize="40sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/textView2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="20dp"
        android:text="@string/welcome_tagline"
        android:textColor="#26D1E7"
        android:textSize="20sp" />

      <TextView
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="18dp"
        android:layout_marginTop="70dp"
        android:layout_marginRight="18dp"
        android:gravity="center"
        android:text="@string/welcome_description"
        android:textColor="#98F6F6F6"
        android:textSize="22sp" />

      <Button
        android:id="@+id/getStartedButton"
        android:layout_width="309dp"
        android:layout_height="69dp"
        android:layout_marginTop="100dp"
        android:layout_marginBottom="10dp"
        android:backgroundTint="#4E6F7577"
        android:text="@string/welcome_enter"
        android:textColor="#CDFFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/textView4"
        android:layout_width="227dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="1dp"
        android:text="@string/welcome_footer"
        android:textColor="#91FFFFFF" />

    </LinearLayout>

  </ScrollView>

  <LinearLayout
    android:id="@+id/languageToggle"
    android:layout_width="wrap_content"
    android:layout_height="44dp"
    android:layout_gravity="top|end"
    android:layout_marginTop="28dp"
    android:layout_marginEnd="24dp"
    android:background="#4E6F7577"
    android:clickable="true"
    android:elevation="12dp"
    android:focusable="true"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingStart="6dp"
    android:paddingEnd="6dp">

    <Button
      android:id="@+id/englishButton"
      android:layout_width="52dp"
      android:layout_height="36dp"
      android:backgroundTint="#26D1E7"
      android:minWidth="0dp"
      android:minHeight="0dp"
      android:padding="0dp"
      android:text="@string/language_english"
      android:textColor="#FFFFFFFF"
      android:textSize="13sp"
      android:textStyle="bold" />

    <View
      android:layout_width="1dp"
      android:layout_height="22dp"
      android:layout_marginStart="4dp"
      android:layout_marginEnd="4dp"
      android:background="#66FFFFFF" />

    <Button
      android:id="@+id/frenchButton"
      android:layout_width="52dp"
      android:layout_height="36dp"
      android:backgroundTint="#33FFFFFF"
      android:minWidth="0dp"
      android:minHeight="0dp"
      android:padding="0dp"
      android:text="@string/language_french"
      android:textColor="#CDFFFFFF"
      android:textSize="13sp"
      android:textStyle="bold" />

  </LinearLayout>

</FrameLayout>
