<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/border"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginBottom="24dp"
      android:gravity="center_vertical"
      android:orientation="horizontal">

      <ImageView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/profile"
        android:padding="8dp" />

      <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:text="SmartHome"
        android:textColor="#212121"
        android:textSize="20sp"
        android:textStyle="bold" />

    </LinearLayout>

    <!-- Alerts Overview -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginBottom="16dp"
      android:background="@drawable/rounded_automation_box"
      android:orientation="vertical"
      android:padding="20dp">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Alerts Overview"
        android:textColor="#212121"
        android:textSize="18sp"
        android:textStyle="bold" />

      <!-- Alert Stats -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Critical Alerts -->
        <LinearLayout
          android:layout_width="8dp"
          android:layout_height="match_parent"
          android:layout_marginEnd="4dp"
          android:layout_weight="1"
          android:background="@drawable/overview_item_box"
          android:gravity="center"
          android:orientation="vertical"
          android:padding="12dp">

          <ImageView
            android:layout_width="wrap_content"
            android:layout_height="33dp"
            android:layout_marginBottom="8dp"
            android:src="@drawable/ic_alert_critical" />

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3"
            android:textColor="#F44336"
            android:textSize="34sp"
            android:textStyle="bold" />

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Critical"
            android:textColor="#757575"
            android:textSize="16sp" />

        </LinearLayout>

        <!-- Warning Alerts -->
        <LinearLayout
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:gravity="center"
          android:orientation="vertical"
          android:background="@drawable/overview_item_box"
          android:padding="12dp"
          android:layout_marginStart="2dp"
          android:layout_marginEnd="2dp">

          <ImageView
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginBottom="8dp"
            android:src="@drawable/ic_alert_warning" />

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5"
            android:textColor="#FF9800"
            android:textSize="34sp"
            android:textStyle="bold" />

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Warning"
            android:textColor="#757575"
            android:textSize="16sp" />

        </LinearLayout>

        <!-- Info Alerts -->
        <LinearLayout
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:gravity="center"
          android:orientation="vertical"
          android:background="@drawable/overview_item_box"
          android:padding="12dp"
          android:layout_marginStart="4dp">

          <ImageView
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginBottom="8dp"
            android:src="@drawable/ic_alert_info" />

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="8"
            android:textColor="#2196F3"
            android:textSize="34sp"
            android:textStyle="bold" />

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Info"
            android:textColor="#757575"
            android:textSize="16sp" />

        </LinearLayout>

      </LinearLayout>

    </LinearLayout>

    <!-- Recent Alerts -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="@drawable/rounded_automation_box"
      android:orientation="vertical"
      android:padding="20dp">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Recent Alerts"
        android:textColor="#212121"
        android:textSize="18sp"
        android:textStyle="bold" />

      <!-- Filter by State -->
      <LinearLayout
        android:layout_width="292dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:orientation="vertical">

        <!-- State Filter Boxes -->
        <LinearLayout
          android:layout_width="290dp"
          android:layout_height="wrap_content"
          android:layout_marginLeft="20dp"
          android:orientation="horizontal">

          <!-- All State -->
          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="@drawable/oval_filter_active"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            android:text="All"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

          <!-- Critical State -->
          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="@drawable/oval_filter_inactive"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            android:text="Critical"
            android:textColor="#757575"
            android:textSize="12sp"
            android:textStyle="bold" />

          <!-- Warning State -->
          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="@drawable/oval_filter_inactive"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            android:text="Warning"
            android:textColor="#757575"
            android:textSize="12sp"
            android:textStyle="bold" />

          <!-- Info State -->
          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/oval_filter_inactive"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            android:text="Info"
            android:textColor="#757575"
            android:textSize="12sp"
            android:textStyle="bold" />

        </LinearLayout>

      </LinearLayout>

      <!-- Alert Item 1 - Critical -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@drawable/alert_critical_background"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Alert Header: Logo, State, Location -->
        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginBottom="8dp"
          android:gravity="center_vertical"
          android:orientation="horizontal">

          <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_alert_critical" />

          <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Critical"
            android:textColor="#F44336"
            android:textSize="14sp"
            android:textStyle="bold" />

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Front Door"
            android:textColor="#757575"
            android:textSize="12sp" />

        </LinearLayout>

        <!-- Alert Name -->
        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginBottom="4dp"
          android:text="Security Breach Detected"
          android:textColor="#212121"
          android:textSize="16sp"
          android:textStyle="bold" />

        <!-- Alert Description -->
        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="Front door unlocked at 2:30 AM - Immediate action required"
          android:textColor="#757575"
          android:textSize="14sp" />

      </LinearLayout>

      <!-- Alert Item 2 - Warning -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@drawable/alert_warning_background"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Alert Header: Logo, State, Location -->
        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginBottom="8dp"
          android:gravity="center_vertical"
          android:orientation="horizontal">

          <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_alert_warning" />

          <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Warning"
            android:textColor="#FF9800"
            android:textSize="14sp"
            android:textStyle="bold" />

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Living Room"
            android:textColor="#757575"
            android:textSize="12sp" />

        </LinearLayout>

        <!-- Alert Name -->
        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginBottom="4dp"
          android:text="High Energy Consumption"
          android:textColor="#212121"
          android:textSize="16sp"
          android:textStyle="bold" />

        <!-- Alert Description -->
        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="AC system using 25% more power than usual - Check thermostat settings"
          android:textColor="#757575"
          android:textSize="14sp" />

      </LinearLayout>

      <!-- Alert Item 3 - Info -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@drawable/alert_info_background"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Alert Header: Logo, State, Location -->
        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginBottom="8dp"
          android:gravity="center_vertical"
          android:orientation="horizontal">

          <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_alert_info" />

          <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Info"
            android:textColor="#2196F3"
            android:textSize="14sp"
            android:textStyle="bold" />

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Backyard"
            android:textColor="#757575"
            android:textSize="12sp" />

        </LinearLayout>

        <!-- Alert Name -->
        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginBottom="4dp"
          android:text="Motion Detected"
          android:textColor="#212121"
          android:textSize="16sp"
          android:textStyle="bold" />

        <!-- Alert Description -->
        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="Movement detected in backyard - Security camera triggered"
          android:textColor="#757575"
          android:textSize="14sp" />

      </LinearLayout>

    </LinearLayout>

  </LinearLayout>

</ScrollView>
