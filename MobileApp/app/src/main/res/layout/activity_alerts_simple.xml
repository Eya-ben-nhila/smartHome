<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/background"
  android:orientation="vertical">

  <ScrollView
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="@color/border"
      android:orientation="vertical"
      android:padding="16dp">

      <!-- Header -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
          android:id="@+id/profilePicture"
          android:layout_width="40dp"
          android:layout_height="40dp"
          android:background="@drawable/profile"
          android:padding="8dp" />

        <TextView
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_marginStart="12dp"
          android:layout_weight="1"
          android:text="@string/app_smart_home"
          android:textColor="#212121"
          android:textSize="20sp"
          android:textStyle="bold" />

      </LinearLayout>

      <!-- Title Border -->
      <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="16dp"
        android:background="@color/gray_400" />

      <!-- Alerts Overview -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/rounded_automation_box"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginBottom="16dp"
          android:text="@string/alerts_overview"
          android:textColor="#212121"
          android:textSize="18sp"
          android:textStyle="bold" />

        <!-- Alert Stats -->
        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal">

          <!-- Critical Alerts -->
          <LinearLayout
            android:layout_width="8dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/overview_item_box"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="12dp">

            <ImageView
              android:layout_width="wrap_content"
              android:layout_height="33dp"
              android:layout_marginBottom="8dp"
              android:src="@drawable/ic_alert_critical" />

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="3"
              android:textColor="#000000"
              android:textSize="34sp"
              android:textStyle="bold" />

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/alerts_critical"
              android:textColor="#757575"
              android:textSize="16sp" />

          </LinearLayout>

          <!-- Warning Alerts -->
          <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:layout_weight="1"
            android:background="@drawable/overview_item_box"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="12dp">

            <ImageView
              android:layout_width="wrap_content"
              android:layout_height="36dp"
              android:layout_marginBottom="8dp"
              android:src="@drawable/ic_alert_warning" />

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="5"
              android:textColor="#000000"
              android:textSize="34sp"
              android:textStyle="bold" />

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/alerts_warning"
              android:textColor="#757575"
              android:textSize="16sp" />

          </LinearLayout>

          <!-- Info Alerts -->
          <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/overview_item_box"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="12dp">

            <ImageView
              android:layout_width="wrap_content"
              android:layout_height="36dp"
              android:layout_marginBottom="8dp"
              android:src="@drawable/ic_alert_info" />

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="8"
              android:textColor="#000000"
              android:textSize="34sp"
              android:textStyle="bold" />

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/alerts_info"
              android:textColor="#757575"
              android:textSize="16sp" />

          </LinearLayout>

        </LinearLayout>

      </LinearLayout>

      <!-- Recent Alerts -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_automation_box"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginBottom="16dp"
          android:text="@string/alerts_recent"
          android:textColor="#212121"
          android:textSize="18sp"
          android:textStyle="bold" />

        <!-- Filter by State -->
        <LinearLayout
          android:layout_width="292dp"
          android:layout_height="wrap_content"
          android:layout_marginBottom="20dp"
          android:orientation="vertical">

          <!-- State Filter Boxes -->
          <LinearLayout
            android:layout_width="308dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:orientation="horizontal">

            <!-- All State -->
            <TextView
              android:id="@+id/filterAll"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginEnd="8dp"
              android:background="@drawable/oval_filter_active"
              android:paddingStart="16dp"
              android:paddingTop="8dp"
              android:paddingEnd="16dp"
              android:paddingBottom="8dp"
              android:text="@string/alerts_all"
              android:textColor="#FFFFFF"
              android:textSize="12sp"
              android:textStyle="bold" />

            <!-- Critical State -->
            <TextView
              android:id="@+id/filterCritical"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginEnd="8dp"
              android:background="@drawable/oval_filter_inactive"
              android:paddingStart="16dp"
              android:paddingTop="8dp"
              android:paddingEnd="16dp"
              android:paddingBottom="8dp"
              android:text="@string/alerts_critical"
              android:textColor="#757575"
              android:textSize="12sp"
              android:textStyle="bold" />

            <!-- Warning State -->
            <TextView
              android:id="@+id/filterWarning"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginEnd="8dp"
              android:background="@drawable/oval_filter_inactive"
              android:paddingStart="16dp"
              android:paddingTop="8dp"
              android:paddingEnd="16dp"
              android:paddingBottom="8dp"
              android:text="@string/alerts_warning"
              android:textColor="#757575"
              android:textSize="12sp"
              android:textStyle="bold" />

            <!-- Info State -->
            <TextView
              android:id="@+id/filterInfo"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:background="@drawable/oval_filter_inactive"
              android:paddingStart="16dp"
              android:paddingTop="8dp"
              android:paddingEnd="16dp"
              android:paddingBottom="8dp"
              android:text="@string/alerts_info"
              android:textColor="#757575"
              android:textSize="12sp"
              android:textStyle="bold" />

          </LinearLayout>

        </LinearLayout>

        <!-- Alert Item 1 - Critical -->
        <LinearLayout
          android:id="@+id/alertCard1"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginBottom="12dp"
          android:background="@drawable/alert_critical_background"
          android:orientation="vertical"
          android:padding="16dp">

          <!-- Alert Header: Logo, State, Location -->
          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
              android:layout_width="24dp"
              android:layout_height="24dp"
              android:layout_marginEnd="12dp"
              android:src="@drawable/ic_alert_critical" />

            <TextView
              android:id="@+id/alertStatus1"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="@string/alerts_critical"
              android:textColor="#F44336"
              android:textSize="14sp"
              android:textStyle="bold" />

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/dashboard_front_door"
              android:textColor="#757575"
              android:textSize="12sp" />

          </LinearLayout>

          <!-- Alert Name -->
          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="@string/alerts_security_breach"
            android:textColor="#212121"
            android:textSize="16sp"
            android:textStyle="bold" />

          <!-- Alert Description -->
          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/alerts_front_door_message"
            android:textColor="#757575"
            android:textSize="14sp" />

          <!-- Dismiss Button -->
          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
              android:id="@+id/dismissAlert1"
              android:layout_width="wrap_content"
              android:layout_height="32dp"
              android:background="@drawable/rounded_button_red"
              android:paddingStart="12dp"
              android:paddingTop="6dp"
              android:paddingEnd="12dp"
              android:paddingBottom="6dp"
              android:text="@string/alerts_acknowledge"
              android:textColor="@color/white"
              android:textSize="10sp"
              android:textStyle="bold"
              android:gravity="center" />

          </LinearLayout>

        </LinearLayout>

        <!-- Alert Item 2 - Warning -->
        <LinearLayout
          android:id="@+id/alertCard2"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginBottom="12dp"
          android:background="@drawable/alert_warning_background"
          android:orientation="vertical"
          android:padding="16dp">

          <!-- Alert Header: Logo, State, Location -->
          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
              android:layout_width="24dp"
              android:layout_height="24dp"
              android:layout_marginEnd="12dp"
              android:src="@drawable/ic_alert_warning" />

            <TextView
              android:id="@+id/alertStatus2"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="@string/alerts_warning"
              android:textColor="#FF9800"
              android:textSize="14sp"
              android:textStyle="bold" />

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/alerts_kitchen"
              android:textColor="#757575"
              android:textSize="12sp" />

          </LinearLayout>

          <!-- Alert Name -->
          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="@string/alerts_high_energy"
            android:textColor="#212121"
            android:textSize="16sp"
            android:textStyle="bold" />

          <!-- Alert Description -->
          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/alerts_high_energy_message"
            android:textColor="#757575"
            android:textSize="14sp" />

          <!-- Dismiss Button -->
          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
              android:id="@+id/dismissAlert2"
              android:layout_width="wrap_content"
              android:layout_height="32dp"
              android:background="@drawable/rounded_button_orange"
              android:paddingStart="12dp"
              android:paddingTop="6dp"
              android:paddingEnd="12dp"
              android:paddingBottom="6dp"
              android:text="@string/alerts_acknowledge"
              android:textColor="@color/white"
              android:textSize="10sp"
              android:textStyle="bold"
              android:gravity="center" />

          </LinearLayout>

        </LinearLayout>

        <!-- Alert Item 3 - Info -->
        <LinearLayout
          android:id="@+id/alertCard3"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginBottom="12dp"
          android:background="@drawable/alert_info_background"
          android:orientation="vertical"
          android:padding="16dp">

          <!-- Alert Header: Logo, State, Location -->
          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
              android:layout_width="24dp"
              android:layout_height="24dp"
              android:layout_marginEnd="12dp"
              android:src="@drawable/ic_alert_info" />

            <TextView
              android:id="@+id/alertStatus3"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="@string/alerts_info"
              android:textColor="#2196F3"
              android:textSize="14sp"
              android:textStyle="bold" />

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/security_backyard"
              android:textColor="#757575"
              android:textSize="12sp" />

          </LinearLayout>

          <!-- Alert Name -->
          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="@string/alerts_motion_detected"
            android:textColor="#212121"
            android:textSize="16sp"
            android:textStyle="bold" />

          <!-- Alert Description -->
          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/alerts_motion_message"
            android:textColor="#757575"
            android:textSize="14sp" />

          <!-- Dismiss Button -->
          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
              android:id="@+id/dismissAlert3"
              android:layout_width="wrap_content"
              android:layout_height="32dp"
              android:background="@drawable/rounded_button_blue"
              android:paddingStart="12dp"
              android:paddingTop="6dp"
              android:paddingEnd="12dp"
              android:paddingBottom="6dp"
              android:text="@string/alerts_acknowledge"
              android:textColor="@color/white"
              android:textSize="10sp"
              android:textStyle="bold"
              android:gravity="center" />

          </LinearLayout>

        </LinearLayout>

        <!-- Alert Item 4 - Critical -->
        <LinearLayout
          android:id="@+id/alertCard4"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginBottom="12dp"
          android:background="@drawable/alert_critical_background"
          android:orientation="vertical"
          android:padding="16dp">

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
              android:layout_width="24dp"
              android:layout_height="24dp"
              android:layout_marginEnd="12dp"
              android:src="@drawable/ic_alert_critical" />

            <TextView
              android:id="@+id/alertStatus4"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="@string/alerts_critical"
              android:textColor="#F44336"
              android:textSize="14sp"
              android:textStyle="bold" />

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/dashboard_living_room"
              android:textColor="#757575"
              android:textSize="12sp" />

          </LinearLayout>

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="@string/alerts_gas_leak"
            android:textColor="#212121"
            android:textSize="16sp"
            android:textStyle="bold" />

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/alerts_gas_message"
            android:textColor="#757575"
            android:textSize="14sp" />

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
              android:id="@+id/dismissAlert4"
              android:layout_width="wrap_content"
              android:layout_height="32dp"
              android:background="@drawable/rounded_button_red"
              android:paddingStart="12dp"
              android:paddingTop="6dp"
              android:paddingEnd="12dp"
              android:paddingBottom="6dp"
              android:text="@string/alerts_acknowledge"
              android:textColor="@color/white"
              android:textSize="10sp"
              android:textStyle="bold"
              android:gravity="center" />

          </LinearLayout>

        </LinearLayout>

        <!-- Alert Item 5 - Warning -->
        <LinearLayout
          android:id="@+id/alertCard5"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginBottom="12dp"
          android:background="@drawable/alert_warning_background"
          android:orientation="vertical"
          android:padding="16dp">

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
              android:layout_width="24dp"
              android:layout_height="24dp"
              android:layout_marginEnd="12dp"
              android:src="@drawable/ic_alert_warning" />

            <TextView
              android:id="@+id/alertStatus5"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="@string/alerts_warning"
              android:textColor="#FF9800"
              android:textSize="14sp"
              android:textStyle="bold" />

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/dashboard_front_door"
              android:textColor="#757575"
              android:textSize="12sp" />

          </LinearLayout>

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="@string/alerts_low_battery"
            android:textColor="#212121"
            android:textSize="16sp"
            android:textStyle="bold" />

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/alerts_low_battery_message"
            android:textColor="#757575"
            android:textSize="14sp" />

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
              android:id="@+id/dismissAlert5"
              android:layout_width="wrap_content"
              android:layout_height="32dp"
              android:background="@drawable/rounded_button_orange"
              android:paddingStart="12dp"
              android:paddingTop="6dp"
              android:paddingEnd="12dp"
              android:paddingBottom="6dp"
              android:text="@string/alerts_acknowledge"
              android:textColor="@color/white"
              android:textSize="10sp"
              android:textStyle="bold"
              android:gravity="center" />

          </LinearLayout>

        </LinearLayout>

      </LinearLayout>

      <!-- Add Rule Section -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/overview_item_box"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Section Header -->
        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:gravity="center_vertical"
          android:orientation="horizontal"
          android:layout_marginBottom="16dp">

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️"
            android:textSize="20sp"
            android:layout_marginEnd="8dp" />

          <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/alerts_add_rule_title"
            android:textColor="#212121"
            android:textSize="16sp"
            android:textStyle="bold" />

        </LinearLayout>

        <!-- Rule Type Selection -->
        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/alerts_alert_type"
          android:textColor="#757575"
          android:textSize="12sp"
          android:layout_marginBottom="4dp" />

        <Spinner
          android:id="@+id/alertTypeSpinner"
          android:layout_width="match_parent"
          android:layout_height="40dp"
          android:background="@drawable/rounded_input_background"
          android:layout_marginBottom="12dp" />

        <!-- Condition Input -->
        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/alerts_condition"
          android:textColor="#757575"
          android:textSize="12sp"
          android:layout_marginBottom="4dp" />

        <EditText
          android:id="@+id/conditionEditText"
          android:layout_width="match_parent"
          android:layout_height="40dp"
          android:background="@drawable/rounded_input_background"
          android:hint="@string/alerts_condition_hint"
          android:paddingStart="12dp"
          android:paddingEnd="12dp"
          android:textSize="14sp"
          android:layout_marginBottom="12dp" />

        <!-- Threshold Input -->
        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/alerts_threshold"
          android:textColor="#757575"
          android:textSize="12sp"
          android:layout_marginBottom="4dp" />

        <EditText
          android:id="@+id/thresholdEditText"
          android:layout_width="match_parent"
          android:layout_height="40dp"
          android:background="@drawable/rounded_input_background"
          android:hint="@string/alerts_threshold_hint"
          android:inputType="number"
          android:paddingStart="12dp"
          android:paddingEnd="12dp"
          android:textSize="14sp"
          android:layout_marginBottom="16dp" />

        <!-- Add Rule Button -->
        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:gravity="center"
          android:orientation="horizontal">

          <TextView
            android:id="@+id/addRuleButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/rounded_button_blue"
            android:paddingStart="20dp"
            android:paddingTop="8dp"
            android:paddingEnd="20dp"
            android:paddingBottom="8dp"
            android:text="@string/alerts_add_rule"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center" />

        </LinearLayout>

      </LinearLayout>

    </LinearLayout>

  </ScrollView>

        <!-- Bottom Navigation -->
        <include
            android:id="@+id/navigation"
            layout="@layout/new_bottom_navigation" />

</LinearLayout>
