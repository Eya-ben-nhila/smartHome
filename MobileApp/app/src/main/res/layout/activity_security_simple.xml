<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/border"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_margin="8dp"
          android:background="@drawable/rounded_box_background"
          android:gravity="center_vertical"
          android:orientation="horizontal"
          android:padding="16dp">

          <!-- Profile Picture -->
          <ImageView
            android:id="@+id/profilePicture"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/profile" />

          <!-- App Name -->
          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_smart_home"
            android:textColor="#212121"
            android:textSize="24sp"
            android:textStyle="bold" />

        </LinearLayout>

        <!-- Title Border -->
        <View
          android:layout_width="390dp"
          android:layout_height="1dp"
          android:layout_marginLeft="10dp"
          android:layout_marginBottom="16dp"
          android:background="@color/gray_400" />

        <!-- Camera Feeds Section -->
        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_margin="8dp"
          android:background="@drawable/box_with_border"
          android:orientation="vertical"
          android:padding="20dp">

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/security_cameras"
            android:textColor="#212121"
            android:textSize="16sp"
            android:textStyle="bold" />

          <!-- Camera Grid -->
          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top Row Cameras -->
            <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_marginBottom="8dp"
              android:orientation="horizontal">

              <!-- Front Door Camera -->
              <LinearLayout
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="#E3F2FD"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/dashboard_front_door"
                  android:textColor="#212121"
                  android:textSize="12sp"
                  android:textStyle="bold" />

                <View
                  android:layout_width="match_parent"
                  android:layout_height="0dp"
                  android:layout_marginVertical="4dp"
                  android:layout_weight="1"
                  android:background="@drawable/frontdoor" />

                <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/security_live"
                  android:textColor="#4CAF50"
                  android:textSize="10sp" />

              </LinearLayout>

              <!-- Backyard Camera -->
              <LinearLayout
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:background="#E3F2FD"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/security_backyard"
                  android:textColor="#212121"
                  android:textSize="12sp"
                  android:textStyle="bold" />

                <View
                  android:layout_width="match_parent"
                  android:layout_height="0dp"
                  android:layout_marginVertical="4dp"
                  android:layout_weight="1"
                  android:background="@drawable/backyard" />

                <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/security_live"
                  android:textColor="#4CAF50"
                  android:textSize="10sp" />

              </LinearLayout>

            </LinearLayout>

            <!-- Bottom Row Cameras -->
            <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="horizontal">

              <!-- Garage Camera -->
              <LinearLayout
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="#E3F2FD"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/security_garage"
                  android:textColor="#212121"
                  android:textSize="12sp"
                  android:textStyle="bold" />

                <View
                  android:layout_width="match_parent"
                  android:layout_height="0dp"
                  android:layout_marginVertical="4dp"
                  android:layout_weight="1"
                  android:background="@drawable/garage" />

                <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/security_live"
                  android:textColor="#4CAF50"
                  android:textSize="10sp" />

              </LinearLayout>

              <!-- Driveway Camera -->
              <LinearLayout
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:background="#E3F2FD"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/security_driveway"
                  android:textColor="#212121"
                  android:textSize="12sp"
                  android:textStyle="bold" />

                <View
                  android:layout_width="match_parent"
                  android:layout_height="0dp"
                  android:layout_marginVertical="4dp"
                  android:layout_weight="1"
                  android:background="@drawable/backyard" />

                <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/security_live"
                  android:textColor="#4CAF50"
                  android:textSize="10sp" />

              </LinearLayout>

            </LinearLayout>

          </LinearLayout>

        </LinearLayout>

        <!-- Security Controls -->
        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_margin="8dp"
          android:background="@drawable/box_with_border"
          android:orientation="vertical"
          android:padding="20dp">

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/security_controls"
            android:textColor="#212121"
            android:textSize="16sp"
            android:textStyle="bold" />

          <!-- Control Boxes -->
          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="vertical">

            <!-- Arm System Box -->
            <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="80dp"
              android:layout_marginBottom="8dp"
              android:background="#3BC2C7CC"
              android:gravity="center_vertical"
              android:orientation="horizontal"
              android:padding="16dp">

              <!-- Logo -->
              <ImageView
                app:tint="#4CAF50"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="16dp"
                android:src="@android:drawable/ic_menu_preferences" />

              <!-- Name and State -->
              <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/security_arm_system"
                  android:textColor="#212121"
                  android:textSize="14sp"
                  android:textStyle="bold" />

                <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/security_armed"
                  android:textColor="#4CAF50"
                  android:textSize="12sp" />

              </LinearLayout>

              <!-- Switch Button -->
              <Switch
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:thumbTint="#FDFDFD"
                android:trackTint="#080D31" />

            </LinearLayout>

            <!-- Lock Doors Box -->
            <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="80dp"
              android:layout_marginBottom="8dp"
              android:background="#3BC2C7CC"
              android:gravity="center_vertical"
              android:orientation="horizontal"
              android:padding="16dp">

              <!-- Logo -->
              <ImageView
                app:tint="#4CAF50"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="16dp"
                android:src="@android:drawable/ic_lock_lock" />

              <!-- Name and State -->
              <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/security_lock_doors"
                  android:textColor="#212121"
                  android:textSize="14sp"
                  android:textStyle="bold" />

                <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/security_locked"
                  android:textColor="#4CAF50"
                  android:textSize="12sp" />

              </LinearLayout>

              <!-- Switch Button -->
              <Switch
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:thumbTint="#FDFDFD"
                android:trackTint="#0061A4" />

            </LinearLayout>

            <!-- Motion Detection Box -->
            <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="80dp"
              android:background="#3BC2C7CC"
              android:gravity="center_vertical"
              android:orientation="horizontal"
              android:padding="16dp">

              <!-- Logo -->
              <ImageView
                app:tint="#FF9800"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="16dp"
                android:src="@android:drawable/ic_menu_recent_history" />

              <!-- Name and State -->
              <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/security_motion_detection"
                  android:textColor="#212121"
                  android:textSize="14sp"
                  android:textStyle="bold" />

                <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/security_standby"
                  android:textColor="#FF9800"
                  android:textSize="12sp" />

              </LinearLayout>

              <!-- Switch Button -->
              <Switch
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                android:thumbTint="#FFFFFF"
                android:trackTint="#0C1442" />

            </LinearLayout>

          </LinearLayout>

        </LinearLayout>

      </LinearLayout>

    </ScrollView>

        <!-- Bottom Navigation -->
        <include
            android:id="@+id/navigation"
            layout="@layout/new_bottom_navigation" />

</LinearLayout>
