<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/background"
  android:orientation="vertical">

  <ScrollView
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="@color/border"
      android:orientation="vertical"
      android:padding="16dp">

      <!-- Header -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
          android:id="@+id/profilePicture"
          android:layout_width="40dp"
          android:layout_height="40dp"
          android:background="@drawable/profile"
          android:padding="8dp" />

        <TextView
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_marginStart="12dp"
          android:layout_weight="1"
          android:text="@string/app_smart_home"
          android:textColor="#212121"
          android:textSize="20sp"
          android:textStyle="bold" />

        <!-- Header Settings Button -->
        <ImageView
          android:id="@+id/headerSettingsButton"
          android:layout_width="24dp"
          android:layout_height="24dp"
          android:layout_marginEnd="8dp"
          android:src="@android:drawable/ic_menu_preferences"
          android:background="?android:attr/selectableItemBackgroundBorderless"
          android:padding="4dp" />

        <!-- Header Bell Button -->
        <ImageView
          android:id="@+id/headerBellButton"
          android:layout_width="24dp"
          android:layout_height="24dp"
          android:src="@android:drawable/ic_dialog_alert"
          android:background="?android:attr/selectableItemBackgroundBorderless"
          android:padding="4dp" />

      </LinearLayout>

      <!-- Title Border -->
      <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="16dp"
        android:background="@color/gray_400" />

      <!-- Daily Debrief Section -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/rounded_automation_box"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginBottom="16dp"
          android:text="@string/activity_debrief_title"
          android:textColor="#212121"
          android:textSize="18sp"
          android:textStyle="bold" />

        <!-- Brief Description -->
        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginBottom="20dp"
          android:lineSpacingExtra="4dp"
          android:text="@string/activity_debrief_body"
          android:textColor="#757575"
          android:textSize="14sp" />

        <!-- Three Status Cards -->
        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal">

          <!-- System State Card -->
          <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/overview_item_box"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="12dp">

            <ImageView
              android:layout_width="24dp"
              android:layout_height="24dp"
              android:layout_marginBottom="6dp"
              android:src="@drawable/a" />

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginBottom="2dp"
              android:text="@string/activity_secure"
              android:textColor="#000000"
              android:textSize="14sp"
              android:textStyle="bold" />

          </LinearLayout>

          <!-- Temperature Card -->
          <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:layout_weight="1"
            android:background="@drawable/overview_item_box"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="12dp">

            <ImageView
              android:layout_width="24dp"
              android:layout_height="24dp"
              android:layout_marginBottom="6dp"
              android:src="@drawable/b" />

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginBottom="2dp"
              android:text="22°C"
              android:textColor="#000000"
              android:textSize="14sp"
              android:textStyle="bold" />

          </LinearLayout>

          <!-- Energy Usage Card -->
          <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/overview_item_box"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="12dp">

            <ImageView
              android:layout_width="24dp"
              android:layout_height="24dp"
              android:layout_marginBottom="6dp"
              android:src="@drawable/c" />

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginBottom="2dp"
              android:text="@string/activity_ready"
              android:textColor="#000000"
              android:textSize="14sp"
              android:textStyle="bold" />

          </LinearLayout>

        </LinearLayout>

      </LinearLayout>

      <!-- Activity Timeline Section -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/rounded_automation_box"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginBottom="16dp"
          android:orientation="horizontal">

          <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="@string/activity_timeline"
            android:textColor="#212121"
            android:textSize="20sp"
            android:textStyle="bold" />

        </LinearLayout>

        <!-- Title Border -->
        <View
          android:layout_width="match_parent"
          android:layout_height="1dp"
          android:layout_marginBottom="16dp"
          android:background="@drawable/title_border" />

        <!-- Timeline Items -->
        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical">

          <!-- Door Opened Item -->
          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/timeline_item_background"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
              android:layout_width="40dp"
              android:layout_height="40dp"
              android:layout_marginEnd="12dp"
              android:src="@drawable/d" />

            <LinearLayout
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:orientation="vertical">

              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/activity_delivery"
                android:textColor="#212121"
                android:textSize="14sp"
                android:textStyle="bold" />

              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/activity_front_door_unlocked"
                android:textColor="#757575"
                android:textSize="12sp" />

            </LinearLayout>

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="7:30 AM"
              android:textColor="#9E9E9E"
              android:textSize="12sp" />

          </LinearLayout>

          <!-- AC On Item -->
          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/timeline_item_background"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
              android:layout_width="40dp"
              android:layout_height="40dp"
              android:layout_marginEnd="12dp"
              android:src="@drawable/e" />

            <LinearLayout
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:orientation="vertical">

              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/activity_motion_backyard"
                android:textColor="#212121"
                android:textSize="14sp"
                android:textStyle="bold" />

              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/activity_backyard_camera"
                android:textColor="#757575"
                android:textSize="12sp" />

            </LinearLayout>

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="2:00 PM"
              android:textColor="#9E9E9E"
              android:textSize="12sp" />

          </LinearLayout>

          <!-- Lights On Item -->
          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/timeline_item_background"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
              android:layout_width="40dp"
              android:layout_height="40dp"
              android:layout_marginEnd="12dp"
              android:src="@drawable/f" />

            <LinearLayout
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:orientation="vertical">

              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/activity_front_door_unlocked"
                android:textColor="#212121"
                android:textSize="14sp"
                android:textStyle="bold" />

              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/activity_by_emma"
                android:textColor="#757575"
                android:textSize="12sp" />

            </LinearLayout>

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="8:30 PM"
              android:textColor="#9E9E9E"
              android:textSize="12sp" />

          </LinearLayout>

          <!-- Motion Detected Item -->
          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/motion_item_background"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
              android:layout_width="40dp"
              android:layout_height="40dp"
              android:layout_marginEnd="12dp"
              android:src="@drawable/g" />

            <LinearLayout
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:orientation="vertical">

              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/activity_temperature_alert"
                android:textColor="#212121"
                android:textSize="14sp"
                android:textStyle="bold" />

              <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Living Room:26°C"
                android:textColor="#757575"
                android:textSize="12sp" />

            </LinearLayout>

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="9:15 PM"
              android:textColor="#9E9E9E"
              android:textSize="12sp" />

          </LinearLayout>

        </LinearLayout>

      </LinearLayout>

    </LinearLayout>

  </ScrollView>

        <!-- Bottom Navigation -->
        <include
            android:id="@+id/navigation"
            layout="@layout/new_bottom_navigation" />

</LinearLayout>
